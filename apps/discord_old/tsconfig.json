{
    "extends": "@dotabot.js/tsconfig/base.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true
    },
    "include": ["src/**/*"]
}