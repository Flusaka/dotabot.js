{
    "extends": "@dotabot.js/tsconfig/base.json",
    "compilerOptions": {
        "allowJs": true,
        "outDir": "dist",
        "resolvePackageJsonImports": true,
        "skipLibCheck": true,
        "module": "preserve",
        "moduleResolution": "bundler",
		"removeComments": true
    },
    "include": ["src"]
}