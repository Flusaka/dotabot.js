    "compilerOptions": {
        "allowJs": true,
        "outDir": "../dist",
        "rootDir": ".",
        "baseUrl": ".",
        "resolvePackageJsonImports": true,
        "skipLibCheck": true,
        "module": "preserve",
        "moduleResolution": "bundler"
    },
    "include": [".", "./**/*"],
    "exclude": ["./tsconfig.json"]
