{
    "extends": "@dotabot.js/tsconfig/base.json",
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"],
    "compilerOptions": {
        "strictNullChecks": true,
        "emitDecoratorMetadata": false,
        "experimentalDecorators": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2023",
        "esModuleInterop": true,
    }
}