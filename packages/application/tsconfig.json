{
    "extends": "@dotabot.js/tsconfig/base.json",
    "compilerOptions": {
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "allowJs": true,
        "outDir": "dist",
        "resolvePackageJsonImports": true,
        "skipLibCheck": true,
        "module": "preserve",
        "moduleResolution": "bundler"
    },
    "include": ["src"],
    "exclude": ["./tsconfig.json"]
}